# GitHub bot（Cursor エージェント用 — felix-jp-studio-bot の fine-grained PAT）
# 実際の値は .env.local に保存（gitignore 済み）。repo にコミットしない。
# GITHUB_BOT_TOKEN=

# WordPress
WP_URL=https://example.jp
WP_USER=admin
WP_APP_PASSWORD=

# 投稿制限
MAX_POSTS_PER_RUN=1
PUBLISH_STATE_PATH=state/publish-state.json

# IndexNow（記事マージ後 ping / Vercel キーファイル生成）
# INDEXNOW_KEY=

# 生成（Phase 1）
# GROQ_API_KEY=
# GROQ_MODEL_DEV=llama-3.1-8b-instant
# GROQ_MODEL_PROD=llama-3.3-70b-versatile
