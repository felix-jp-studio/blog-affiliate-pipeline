---
import { getCollection } from "astro:content";
import Breadcrumbs from "../components/Breadcrumbs.astro";
import { categoryMeta } from "../data/category-meta";
import { buildBreadcrumbs } from "../data/site-nav";
import BaseLayout from "../layouts/BaseLayout.astro";

const meta = categoryMeta.trouble;

const articles = (
  await getCollection("articles", ({ data }) => !data.draft)
).sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const troubleArticles = articles.filter((a) => a.data.category === "trouble");
const breadcrumbs = buildBreadcrumbs([{ label: meta.label }]);
---

<BaseLayout title={meta.label} description={meta.description}>
  <Breadcrumbs items={breadcrumbs} />
  <h1>{meta.label}</h1>
  <p class="lead">速度が遅い、開通が遅いなど、よくある悩みへの対処法です。</p>

  {
    troubleArticles.length > 0 ? (
      <ul>
        {troubleArticles.map((article) => {
          const slug = article.id;
          return (
            <li>
              <a href={`/articles/${slug}`}>{article.data.title}</a>
            </li>
          );
        })}
      </ul>
    ) : (
      <p>記事を準備中です。</p>
    )
  }
</BaseLayout>
