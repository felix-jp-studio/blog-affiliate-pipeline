---
import { getCollection } from "astro:content";
import CategoryHub from "../components/CategoryHub.astro";
import { categoryMeta } from "../data/category-meta";
import BaseLayout from "../layouts/BaseLayout.astro";

const meta = categoryMeta.sim;

const articles = (await getCollection("articles", ({ data }) => !data.draft))
  .filter((a) => a.data.category === "sim")
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---

<BaseLayout title={meta.label} description={meta.description} layout="hub">
  <CategoryHub category="sim" articles={articles} />
</BaseLayout>
