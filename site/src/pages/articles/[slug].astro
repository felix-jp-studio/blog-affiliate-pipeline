---
import { getCollection, render } from "astro:content";
import AffiliateDisclosure from "../../components/AffiliateDisclosure.astro";
import ArticleHero from "../../components/ArticleHero.astro";
import ArticleToc from "../../components/ArticleToc.astro";
import Breadcrumbs from "../../components/Breadcrumbs.astro";
import RelatedArticles from "../../components/RelatedArticles.astro";
import SitePublisherBox from "../../components/SitePublisherBox.astro";
import { categoryMeta } from "../../data/category-meta";
import { buildBreadcrumbs } from "../../data/site-nav";
import { hasAffiliateLinks } from "../../utils/affiliate-links";
import {
  extractHeadings,
  getReadingTimeForEntry,
  resolveOgImageUrl,
} from "../../utils/article-meta";
import BaseLayout from "../../layouts/BaseLayout.astro";

export async function getStaticPaths() {
  const entries = await getCollection("articles", ({ data }) => !data.draft);
  return entries.map((entry) => {
    const slug = entry.id;
    return {
      params: { slug },
      props: { entry },
    };
  });
}

const { entry } = Astro.props;
const { Content } = await render(entry);
const slug = entry.id;

const category = categoryMeta[entry.data.category];
const readingTimeMinutes = getReadingTimeForEntry(entry);
const toc = await extractHeadings(entry.body ?? "");
const articleUrl = new URL(`/articles/${slug}`, Astro.site).href;
const ogImage = resolveOgImageUrl(entry.data.eyecatch, entry.data.category);
const publishedTime = entry.data.pubDate.toISOString();

const allArticles = (
  await getCollection("articles", ({ data }) => !data.draft)
).sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const sameCategoryArticles = allArticles.filter(
  (article) => article.data.category === entry.data.category,
);

const breadcrumbs = buildBreadcrumbs([
  { label: category.label, href: category.href },
  { label: entry.data.title },
]);

const showAffiliateDisclosure = hasAffiliateLinks(entry.body ?? "");

const breadcrumbJsonLd = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: breadcrumbs.map((item, index) => ({
    "@type": "ListItem",
    position: index + 1,
    name: item.label,
    ...(item.href ? { item: new URL(item.href, Astro.site).href } : {}),
  })),
};

const articleJsonLd = {
  "@context": "https://schema.org",
  "@type": "Article",
  headline: entry.data.title,
  description: entry.data.description,
  datePublished: publishedTime,
  image: new URL(ogImage, Astro.site).href,
  mainEntityOfPage: articleUrl,
  author: {
    "@type": "Organization",
    name: "SIM・光回線ガイド",
    url: Astro.site,
  },
  publisher: {
    "@type": "Organization",
    name: "SIM・光回線ガイド",
    url: Astro.site,
  },
};
---

<BaseLayout
  title={entry.data.title}
  description={entry.data.description}
  layout="article"
  activeNav={entry.data.category}
  ogType="article"
  ogImage={ogImage}
  publishedTime={publishedTime}
  jsonLd={[articleJsonLd, breadcrumbJsonLd]}
>
  <Breadcrumbs items={breadcrumbs} />
  <article class="article-shell">
    <ArticleHero
      title={entry.data.title}
      description={entry.data.description}
      category={entry.data.category}
      articleType={entry.data.articleType}
      pubDate={entry.data.pubDate}
      readingTimeMinutes={readingTimeMinutes}
      eyecatch={entry.data.eyecatch}
    />
    {showAffiliateDisclosure && <AffiliateDisclosure />}
    <div class="article-content">
      <ArticleToc items={toc} />
      <div class="article-body prose">
        <Content />
      </div>
    </div>
    <SitePublisherBox />
    <RelatedArticles articles={sameCategoryArticles} currentSlug={slug} />
  </article>
</BaseLayout>

<style>
  .article-shell {
    background: var(--bg-article);
    border: 1px solid var(--border);
    border-radius: var(--radius-md);
    box-shadow: var(--shadow-sm);
    padding: 0 0 2rem;
    overflow: hidden;
  }

  .article-shell :global(.article-hero) {
    border-radius: 0;
    margin-bottom: 0;
  }

  .article-shell :global(.affiliate-disclosure) {
    padding-inline: 2.25rem;
  }

  .article-content {
    display: grid;
    grid-template-columns: 1fr;
    gap: 0 2rem;
    padding-inline: 2.25rem;
    padding-top: 1.5rem;
    align-items: start;
  }

  .article-body {
    min-width: 0;
  }

  .article-shell :global(.related-articles) {
    margin-inline: 2.25rem;
  }

  @media (min-width: 1024px) {
    .article-content {
      grid-template-columns: 220px minmax(0, 1fr);
    }
  }

  @media (max-width: 640px) {
    .article-shell :global(.affiliate-disclosure),
    .article-content,
    .article-shell :global(.related-articles) {
      padding-inline: 1.25rem;
    }
  }
</style>
