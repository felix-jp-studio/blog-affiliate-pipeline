---
import Analytics from "../components/Analytics.astro";
import type { CategorySlug } from "../data/category-meta";
import { defaultOgImage } from "../data/category-meta";
import { mainNav } from "../data/site-nav";
import "../styles/tokens.css";
import "../styles/prose.css";

interface Props {
  title: string;
  description?: string;
  layout?: "default" | "article" | "hub";
  activeNav?: CategorySlug;
  ogType?: "website" | "article";
  ogImage?: string;
  publishedTime?: string;
  jsonLd?: Record<string, unknown> | Record<string, unknown>[];
}

const {
  title,
  description = "格安SIM・光回線の比較・乗り換え・お困り解決ガイド",
  layout = "default",
  activeNav,
  ogType = "website",
  ogImage = defaultOgImage,
  publishedTime,
  jsonLd,
} = Astro.props;

const pageTitle =
  title === "SIM・光回線ガイド" ? title : `${title} | SIM・光回線ガイド`;
const canonical =
  Astro.url.pathname === "/"
    ? Astro.site!
    : new URL(Astro.url.pathname, Astro.site).href;
const ogImageUrl = new URL(ogImage, Astro.site).href;
const gscVerification = import.meta.env.PUBLIC_GSC_VERIFICATION;

const mainClass = [
  "container",
  layout === "article" && "layout-article",
  layout === "hub" && "layout-hub",
]
  .filter(Boolean)
  .join(" ");

const jsonLdPayload = jsonLd
  ? Array.isArray(jsonLd)
    ? jsonLd
    : [jsonLd]
  : null;
---

<!doctype html>
<html lang="ja">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <title>{pageTitle}</title>
    <link rel="canonical" href={canonical} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta property="og:type" content={ogType} />
    <meta property="og:site_name" content="SIM・光回線ガイド" />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImageUrl} />
    {
      publishedTime && (
        <meta property="article:published_time" content={publishedTime} />
      )
    }
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />
    {
      gscVerification && (
        <meta name="google-site-verification" content={gscVerification} />
      )
    }
    {
      jsonLdPayload && (
        <script
          type="application/ld+json"
          set:html={JSON.stringify(
            jsonLdPayload.length === 1 ? jsonLdPayload[0] : jsonLdPayload,
          )}
        />
      )
    }
    <Analytics />
  </head>
  <body>
    <header>
      <div class="container header-inner">
        <a class="logo" href="/">SIM・光回線ガイド</a>
        <nav aria-label="メインナビゲーション">
          {
            mainNav.map((item) => {
              const navKey = item.href.replace("/", "") as CategorySlug;
              const isActive = activeNav === navKey;
              return (
                <a
                  href={item.href}
                  class:list={{ "is-active": isActive }}
                  aria-current={isActive ? "page" : undefined}
                >
                  {item.label}
                </a>
              );
            })
          }
        </nav>
      </div>
    </header>
    <main class={mainClass}>
      <slot />
    </main>
    <footer>
      <div class="container footer-inner">
        <p class="footer-lead">
          格安SIM・光回線の比較とお困り解決ガイド。料金・手順は各公式サイトで最新情報をご確認ください。
        </p>
        <nav aria-label="フッターナビゲーション">
          <a href="/about">運営者情報</a>
          <a href="/privacy">プライバシーポリシー</a>
          <a href="/contact">お問い合わせ</a>
        </nav>
        <p class="affiliate-note">
          当サイトはアフィリエイトプログラムにより運営されています。
        </p>
        <p class="copyright">© 2026 SIM・光回線ガイド</p>
      </div>
    </footer>
  </body>
</html>

<style is:global>
  * {
    box-sizing: border-box;
  }

  body {
    margin: 0;
    font-family: var(--font-sans);
    color: var(--text-primary);
    background: #fafafa;
    line-height: var(--line-body);
  }

  a {
    color: var(--accent);
    text-decoration: none;
  }

  a:hover {
    text-decoration: underline;
  }

  .container {
    width: min(960px, calc(100% - 2rem));
    margin-inline: auto;
  }

  .layout-article {
    width: min(var(--width-page), calc(100% - 2rem));
  }

  .layout-hub {
    width: min(var(--width-hub), calc(100% - 2rem));
  }

  header {
    position: sticky;
    top: 0;
    z-index: 100;
    border-bottom: 1px solid var(--border);
    background: rgba(247, 249, 252, 0.92);
    backdrop-filter: blur(8px);
  }

  .header-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    min-height: 4rem;
    padding: 0.75rem 0;
    flex-wrap: wrap;
  }

  .logo {
    font-weight: 700;
    color: var(--text-primary);
    font-size: 1.1rem;
  }

  nav {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
  }

  nav a {
    color: var(--text-secondary);
    font-weight: 500;
    padding: 0.35rem 0.15rem;
    border-bottom: 2px solid transparent;
    text-decoration: none;
  }

  nav a:hover {
    color: var(--accent);
    text-decoration: none;
  }

  nav a.is-active {
    color: var(--accent);
    font-weight: 700;
    border-bottom-color: var(--accent);
  }

  main {
    padding: 2rem 0 3rem;
  }

  footer {
    border-top: 1px solid var(--border);
    background: var(--surface);
    padding: 1.5rem 0;
    color: var(--text-secondary);
    font-size: 0.9rem;
  }

  .footer-inner {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .footer-lead {
    margin: 0;
    max-width: 42rem;
  }

  .affiliate-note {
    margin: 0;
    font-size: 0.85rem;
  }

  h1 {
    font-size: clamp(1.6rem, 4vw, 2rem);
    line-height: var(--line-heading);
    margin: 0 0 1rem;
  }

  h2 {
    font-size: 1.2rem;
    margin: 2rem 0 0.75rem;
  }

  p,
  ul {
    margin: 0 0 1rem;
  }

  .lead {
    color: var(--text-secondary);
    font-size: var(--text-lead);
  }

  .card-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
    gap: 1rem;
    margin-top: 1.5rem;
  }

  .card {
    border: 1px solid var(--border);
    border-radius: var(--radius-sm);
    padding: 1rem;
    background: var(--bg-article);
  }

  .card h2 {
    margin-top: 0;
    font-size: 1.05rem;
  }

  .badge {
    display: inline-block;
    padding: 0.2rem 0.5rem;
    border-radius: 999px;
    background: var(--accent-soft);
    color: var(--accent);
    font-size: 0.8rem;
    margin-bottom: 0.75rem;
  }
</style>
