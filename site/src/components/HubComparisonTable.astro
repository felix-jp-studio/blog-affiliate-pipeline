---
import type {
  HubComparisonColumn,
  HubComparisonRow,
} from "../data/hub-asp-offers";

interface Props {
  title: string;
  note: string;
  columns: HubComparisonColumn[];
  rows: HubComparisonRow[];
}

const { title, note, columns, rows } = Astro.props;
---

<section class="hub-comparison" aria-labelledby="hub-comparison-title">
  <h2 id="hub-comparison-title" class="hub-comparison__title">{title}</h2>
  <div class="table-scroll">
    <table class="hub-comparison__table">
      <thead>
        <tr>
          {columns.map((column) => <th scope="col">{column.label}</th>)}
        </tr>
      </thead>
      <tbody>
        {
          rows.map((row) => (
            <tr>
              {columns.map((column) => (
                <td>{row[column.key] ?? ""}</td>
              ))}
            </tr>
          ))
        }
      </tbody>
    </table>
  </div>
  <p class="hub-comparison__note">{note}</p>
</section>

<style>
  .hub-comparison {
    display: flex;
    flex-direction: column;
    gap: 0.85rem;
  }

  .hub-comparison__title {
    margin: 0;
    font-size: 1.15rem;
    line-height: var(--line-heading);
    color: var(--text-primary);
  }

  .table-scroll {
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
    border: 1px solid var(--border);
    border-radius: var(--radius-md);
    background: var(--bg-article);
  }

  .hub-comparison__table {
    width: 100%;
    min-width: 36rem;
    border-collapse: collapse;
    font-size: 0.9rem;
    line-height: 1.6;
  }

  .hub-comparison__table th,
  .hub-comparison__table td {
    padding: 0.65rem 0.85rem;
    border-bottom: 1px solid var(--border);
    text-align: left;
    vertical-align: top;
  }

  .hub-comparison__table th {
    background: var(--accent-soft);
    font-weight: 700;
    color: var(--text-primary);
    white-space: nowrap;
  }

  .hub-comparison__table tbody tr:last-child td {
    border-bottom: none;
  }

  .hub-comparison__note {
    margin: 0;
    font-size: 0.85rem;
    line-height: 1.65;
    color: var(--text-secondary);
  }
</style>
