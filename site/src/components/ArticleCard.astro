---
import type { ArticleType } from "../data/article-type-labels";
import { articleTypeLabels } from "../data/article-type-labels";
import type { CategorySlug } from "../data/category-meta";
import { categoryMeta } from "../data/category-meta";
import {
  formatArticleDate,
  formatReadingTime,
  getArticleExcerpt,
} from "../utils/article-meta";

interface Props {
  slug: string;
  title: string;
  description: string;
  pubDate: Date;
  category: CategorySlug;
  articleType: ArticleType;
  readingTimeMinutes?: number;
  excerpt?: string;
  eyecatch?: string;
  variant?: "grid" | "compact" | "horizontal";
}

const {
  slug,
  title,
  description,
  pubDate,
  category,
  articleType,
  readingTimeMinutes,
  excerpt,
  eyecatch,
  variant = "grid",
} = Astro.props;

const categoryLabel = categoryMeta[category].label;
const typeLabel = articleTypeLabels[articleType];
const cardExcerpt = getArticleExcerpt(description, excerpt);
const dateLabel = formatArticleDate(pubDate);
const readingLabel =
  readingTimeMinutes !== undefined
    ? formatReadingTime(readingTimeMinutes)
    : undefined;
---

<a
  href={`/articles/${slug}`}
  class:list={["article-card", `article-card--${variant}`, `article-card--${category}`]}
  aria-label={`${title} の記事を読む`}
>
  <div class="article-card__media">
    {
      eyecatch ? (
        <img src={eyecatch} alt="" loading="lazy" decoding="async" />
      ) : (
        <div class="article-card__placeholder" aria-hidden="true">
          {
            category === "sim" && (
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                <rect x="7" y="2" width="10" height="20" rx="2" />
                <circle cx="12" cy="18" r="1" fill="currentColor" stroke="none" />
              </svg>
            )
          }
          {
            category === "hikari" && (
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                <path d="M4 14h16M6 10l6-6 6 6M8 14v6h8v-6" />
              </svg>
            )
          }
          {
            category === "trouble" && (
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                <circle cx="12" cy="12" r="9" />
                <path d="M12 8v5M12 16h.01" />
              </svg>
            )
          }
        </div>
      )
    }
  </div>
  <div class="article-card__body">
    <div class="article-card__chips">
      <span class="chip chip--category">{categoryLabel}</span>
      <span class="chip chip--type">{typeLabel}</span>
    </div>
    <h3 class="article-card__title">{title}</h3>
    <p class="article-card__excerpt">{cardExcerpt}</p>
    <p class="article-card__meta">
      <time datetime={pubDate.toISOString()}>{dateLabel}</time>
      {readingLabel && <span class="article-card__meta-sep">·</span>}
      {readingLabel && <span>{readingLabel}</span>}
    </p>
  </div>
</a>

<style>
  .article-card {
    display: flex;
    flex-direction: column;
    background: var(--bg-article, #fff);
    border: 1px solid var(--border);
    border-radius: var(--radius-md);
    overflow: hidden;
    color: inherit;
    text-decoration: none;
    transition:
      box-shadow 0.2s ease,
      transform 0.2s ease;
  }

  .article-card:hover {
    box-shadow: var(--shadow-md);
    transform: translateY(-2px);
    text-decoration: none;
  }

  .article-card__media {
    aspect-ratio: 16 / 9;
    overflow: hidden;
    background: var(--surface);
  }

  .article-card__media img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .article-card__placeholder {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    color: rgba(255, 255, 255, 0.92);
  }

  .article-card__placeholder svg {
    width: 2.5rem;
    height: 2.5rem;
  }

  .article-card--sim .article-card__placeholder {
    background: var(--gradient-sim);
    color: var(--color-sim);
  }

  .article-card--hikari .article-card__placeholder {
    background: var(--gradient-hikari);
    color: var(--color-hikari);
  }

  .article-card--trouble .article-card__placeholder {
    background: var(--gradient-trouble);
    color: var(--color-trouble);
  }

  .article-card__body {
    padding: 1rem 1.1rem 1.15rem;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    flex: 1;
  }

  .article-card__chips {
    display: flex;
    flex-wrap: wrap;
    gap: 0.35rem;
  }

  .chip {
    display: inline-block;
    padding: 0.15rem 0.55rem;
    border-radius: 999px;
    font-size: 0.75rem;
    font-weight: 600;
    line-height: 1.4;
  }

  .chip--category {
    background: var(--accent-soft);
    color: var(--accent);
  }

  .chip--type {
    background: #f0f4f8;
    color: var(--text-secondary);
  }

  .article-card__title {
    margin: 0;
    font-size: 1rem;
    line-height: 1.45;
    color: var(--text-primary);
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .article-card__excerpt {
    margin: 0;
    font-size: 0.875rem;
    line-height: 1.6;
    color: var(--text-secondary);
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .article-card__meta {
    margin: auto 0 0;
    font-size: 0.8rem;
    color: var(--text-tertiary);
    display: flex;
    align-items: center;
    gap: 0.35rem;
  }

  .article-card__meta-sep {
    color: var(--border-strong);
  }

  .article-card--compact .article-card__media {
    aspect-ratio: 16 / 9;
  }

  .article-card--compact .article-card__body {
    padding: 0.85rem 1rem 1rem;
  }

  .article-card--compact .article-card__title {
    font-size: 0.95rem;
  }

  .article-card--compact .article-card__excerpt {
    -webkit-line-clamp: 2;
    font-size: 0.825rem;
  }

  .article-card--horizontal {
    flex-direction: row;
    align-items: stretch;
  }

  .article-card--horizontal .article-card__media {
    flex: 0 0 38%;
    max-width: 220px;
    aspect-ratio: auto;
    min-height: 140px;
  }

  .article-card--horizontal .article-card__body {
    padding: 1rem 1.15rem;
  }

  @media (max-width: 640px) {
    .article-card--horizontal {
      flex-direction: column;
    }

    .article-card--horizontal .article-card__media {
      flex: none;
      max-width: none;
      aspect-ratio: 16 / 9;
      min-height: 0;
    }
  }
</style>
