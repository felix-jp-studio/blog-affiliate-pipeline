---
import type { ArticleType } from "../data/article-type-labels";
import { articleTypeLabels } from "../data/article-type-labels";
import type { CategorySlug } from "../data/category-meta";
import { categoryMeta } from "../data/category-meta";
import { formatArticleDate, formatReadingTime } from "../utils/article-meta";

interface Props {
  title: string;
  description: string;
  category: CategorySlug;
  articleType: ArticleType;
  pubDate: Date;
  readingTimeMinutes: number;
  eyecatch?: string;
}

const {
  title,
  description,
  category,
  articleType,
  pubDate,
  readingTimeMinutes,
  eyecatch,
} = Astro.props;

const categoryInfo = categoryMeta[category];
const typeLabel = articleTypeLabels[articleType];
const dateLabel = formatArticleDate(pubDate);
const readingLabel = formatReadingTime(readingTimeMinutes);
---

<section class="article-hero" data-category={category}>
  <div class="article-hero__inner">
    <div class="article-hero__chips">
      <span class="chip chip--category">{categoryInfo.label}</span>
      <span class="chip chip--type">{typeLabel}</span>
    </div>
    <h1 class="article-hero__title">{title}</h1>
    <p class="article-hero__lead">{description}</p>
    <p class="article-hero__meta">
      <time datetime={pubDate.toISOString()}>{dateLabel}</time>
      <span class="article-hero__meta-sep">·</span>
      <span>{readingLabel}</span>
    </p>
    {
      eyecatch && (
        <div class="article-hero__eyecatch">
          <img src={eyecatch} alt="" loading="eager" decoding="async" />
        </div>
      )
    }
  </div>
</section>

<style>
  .article-hero {
    background: var(--bg-hero);
    border-radius: var(--radius-md);
    margin-bottom: 1.5rem;
    overflow: hidden;
  }

  .article-hero__inner {
    padding: 2rem 2.25rem;
  }

  .article-hero__chips {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
    margin-bottom: 0.85rem;
  }

  .chip {
    display: inline-block;
    padding: 0.2rem 0.6rem;
    border-radius: 999px;
    font-size: 0.8rem;
    font-weight: 600;
    line-height: 1.4;
  }

  .chip--category {
    background: var(--accent-soft);
    color: var(--accent);
  }

  .chip--type {
    background: #f0f4f8;
    color: var(--text-secondary);
  }

  .article-hero__title {
    margin: 0 0 0.85rem;
    font-family: var(--font-serif);
    font-size: clamp(1.75rem, 4vw, 2.35rem);
    font-weight: 700;
    line-height: var(--line-heading);
    letter-spacing: 0.02em;
    color: var(--text-primary);
  }

  .article-hero__lead {
    margin: 0 0 1rem;
    font-size: var(--text-lead);
    line-height: 1.75;
    color: var(--text-secondary);
    max-width: 42rem;
  }

  .article-hero__meta {
    margin: 0;
    font-size: 0.875rem;
    color: var(--text-tertiary);
    display: flex;
    align-items: center;
    gap: 0.4rem;
  }

  .article-hero__meta-sep {
    color: var(--border-strong);
  }

  .article-hero__eyecatch {
    margin-top: 1.25rem;
    border-radius: var(--radius-sm);
    overflow: hidden;
    max-height: 280px;
  }

  .article-hero__eyecatch img {
    width: 100%;
    height: 100%;
    max-height: 280px;
    object-fit: cover;
    display: block;
  }

  @media (max-width: 640px) {
    .article-hero__inner {
      padding: 1.5rem 1.25rem;
    }
  }
</style>
