---
import type { CategorySlug } from "../data/category-meta";

interface Props {
  category: CategorySlug;
  class?: string;
}

const { category, class: className } = Astro.props;
---

<div
  class:list={[
    "eyecatch-placeholder",
    `eyecatch-placeholder--${category}`,
    className,
  ]}
  aria-hidden="true"
>
  {
    category === "sim" && (
      <svg
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="1.5"
      >
        <rect x="7" y="2" width="10" height="20" rx="2" />
        <circle cx="12" cy="18" r="1" fill="currentColor" stroke="none" />
      </svg>
    )
  }
  {
    category === "hikari" && (
      <svg
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="1.5"
      >
        <path d="M4 14h16M6 10l6-6 6 6M8 14v6h8v-6" />
      </svg>
    )
  }
  {
    category === "trouble" && (
      <svg
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="1.5"
      >
        <circle cx="12" cy="12" r="9" />
        <path d="M12 8v5M12 16h.01" />
      </svg>
    )
  }
</div>

<style>
  .eyecatch-placeholder {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    color: rgba(255, 255, 255, 0.92);
  }

  .eyecatch-placeholder svg {
    width: 2.5rem;
    height: 2.5rem;
  }

  .eyecatch-placeholder--sim {
    background: var(--gradient-sim);
    color: var(--color-sim);
  }

  .eyecatch-placeholder--hikari {
    background: var(--gradient-hikari);
    color: var(--color-hikari);
  }

  .eyecatch-placeholder--trouble {
    background: var(--gradient-trouble);
    color: var(--color-trouble);
  }
</style>
