---
import type { BreadcrumbItem } from "../data/site-nav";

interface Props {
  items: BreadcrumbItem[];
}

const { items } = Astro.props;
---

<nav aria-label="パンくずリスト" class="breadcrumbs">
  <ol>
    {
      items.map((item, index) => {
        const isLast = index === items.length - 1;
        return (
          <li>
            {item.href && !isLast ? (
              <a href={item.href}>{item.label}</a>
            ) : (
              <span aria-current={isLast ? "page" : undefined}>
                {item.label}
              </span>
            )}
          </li>
        );
      })
    }
  </ol>
</nav>

<style>
  .breadcrumbs {
    margin-bottom: 1.25rem;
    font-size: 0.875rem;
    color: var(--muted);
  }

  ol {
    display: flex;
    flex-wrap: wrap;
    gap: 0.35rem;
    list-style: none;
    margin: 0;
    padding: 0;
  }

  li:not(:last-child)::after {
    content: "›";
    margin-left: 0.35rem;
    color: var(--border);
  }

  a {
    color: var(--muted);
  }

  a:hover {
    color: var(--accent);
  }

  span[aria-current="page"] {
    color: var(--text);
  }
</style>
