---
import type { HubAspOffer } from "../data/hub-asp-offers";
import { resolveProgramLabel, resolveProgramUrl } from "../utils/asp-urls";

interface Props {
  title: string;
  offers: HubAspOffer[];
}

const { title, offers } = Astro.props;
---

<section class="hub-asp-cta" aria-labelledby="hub-asp-cta-title">
  <h2 id="hub-asp-cta-title" class="hub-asp-cta__title">{title}</h2>
  <div class="hub-asp-cta__cards">
    {
      offers.map((offer) => {
        const label = resolveProgramLabel(offer.programId);
        const href = resolveProgramUrl(offer.programId);
        const ctaLabel = offer.ctaLabel ?? "公式サイトで確認";

        return (
          <div class="affiliate-cta-block">
            <div class="affiliate-cta-block__content">
              <p class="affiliate-cta-block__title">{label}</p>
              <p class="affiliate-cta-block__desc">{offer.description}</p>
            </div>
            <a
              class="affiliate-link affiliate-cta-block__action"
              href={href}
              rel="sponsored noopener noreferrer"
              target="_blank"
            >
              {ctaLabel}
            </a>
          </div>
        );
      })
    }
  </div>
</section>

<style>
  .hub-asp-cta {
    display: flex;
    flex-direction: column;
    gap: 0.85rem;
  }

  .hub-asp-cta__title {
    margin: 0;
    font-size: 1.15rem;
    line-height: var(--line-heading);
    color: var(--text-primary);
  }

  .hub-asp-cta__cards {
    display: flex;
    flex-direction: column;
    gap: 0.85rem;
  }

  .affiliate-cta-block {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    padding: 1.1rem 1.25rem;
    background: #f0f6ff;
    border: 1px solid var(--border);
    border-left: 4px solid var(--accent);
    border-radius: var(--radius-md);
  }

  .affiliate-cta-block__content {
    flex: 1 1 220px;
    min-width: 0;
  }

  .affiliate-cta-block__title {
    margin: 0 0 0.35rem;
    font-size: 1rem;
    font-weight: 700;
    color: var(--text-primary);
  }

  .affiliate-cta-block__desc {
    margin: 0;
    font-size: 0.875rem;
    line-height: 1.6;
    color: var(--text-secondary);
  }

  .affiliate-link.affiliate-cta-block__action {
    flex-shrink: 0;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 0.65rem 1.25rem;
    border-radius: 6px;
    background: var(--accent);
    color: #fff;
    font-weight: 600;
    font-size: 0.95rem;
    text-decoration: none;
    transition: background 0.15s ease;
  }

  .affiliate-link.affiliate-cta-block__action:hover {
    background: #095aa8;
    text-decoration: none;
  }
</style>
